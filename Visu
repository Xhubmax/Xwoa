    local success, err = pcall(function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/Xhubmax/Gag2/refs/heads/main/Xwoalua"))()
    end)
    
    if success then
        CustomScriptButton.Text = "Loaded Successfully! ✅"
        CustomScriptButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113) -- Green on success
    else
        CustomScriptButton.Text = "Failed to Load ❌"
        CustomScriptButton.BackgroundColor3 = Color3.fromRGB(192, 41, 43) -- Red on error
        warn("Error loading XHubMax: " .. tostring(err))
    end
    
    -- Reset button look after 3 seconds
    task.delay(3, function()
        CustomScriptButton.Text = "Load XHubMax ☄️"
        CustomScriptButton.BackgroundColor3 = Color3.fromRGB(211, 84, 0)
    end)
end)
