local function getWorkspacePrompts()
    local prompts = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then table.insert(prompts, v) end
    end
    return prompts
end

local function checkNearbyPlayers(rootPart)
    for _, p in ipairs(game.Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (p.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude
            if distance < 40 then return true end
        end
    end
    return false
end

local function findBestPrompt(myPosition)
    local allPrompts = getWorkspacePrompts()
    for _, cropName in ipairs(PriorityCrops) do
        for _, prompt in ipairs(allPrompts) do
            local parentName = prompt.Parent and string.lower(prompt.Parent.Name) or ""
            local promptText = string.lower(prompt.ObjectText .. prompt.ActionText .. prompt.Name)
            
            if string.find(promptText, "harvest") or string.find(parentName, "harvest") then
                if string.find(promptText, cropName) or string.find(parentName, cropName) then
                    local targetPart = prompt.Parent
                    if targetPart and targetPart:IsA("BasePart") then
                        if (targetPart.Position - myPosition).Magnitude > 50 then
                            return prompt, targetPart
                        end
                    end
                end
            end
        end
    end
    return nil, nil
end

