local function getWorkspacePrompts()
    local prompts = {}
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            table.insert(prompts, v)
        end
    end
    return prompts
end

-- Player/Admin Detector with Discord Logs
local function checkNearbyPlayers(rootPart)
    for _, p in ipairs(game.Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (p.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude
            if distance < 40 then
                sendDiscordMessage("⚠️ Security Alert (Player Detected)", "Player **" .. p.Name .. "** got too close (" .. math.floor(distance) .. " studs).\nAction: Evaded safely back to home.", 15158332)
                return true
            end
        end
    end
    return false
end

local function runAutoSellAndBuy(rootPart)
    for _, v in ipairs(workspace:GetDescendants()) do
        local name = string.lower(v.Name)
        local isPrompt = v:IsA("ProximityPrompt")
        local text = isPrompt and string.lower(v.ObjectText .. v.ActionText) or ""
        
        if string.find(name, "sell") or string.find(text, "sell") then
            local target = v:IsA("ProximityPrompt") and v.Parent or v
            if target:IsA("BasePart") then
                rootPart.CFrame = target.CFrame + Vector3.new(0, 2, 0)
                task.wait(0.2)
                if isPrompt then fireproximityprompt(v) end
                task.wait(0.3)
            end
        end
        
        if string.find(name, "seed") or string.find(name, "buy") or string.find(text, "seed") then
            local target = v:IsA("ProximityPrompt") and v.Parent or v
            if target:IsA("BasePart") then
                rootPart.CFrame = target.CFrame + Vector3.new(0, 2, 0)
                task.wait(0.2)
                if isPrompt then fireproximityprompt(v) end
                task.wait(0.3)
            end
        end
    end
end

local function findBestPrompt(myPosition)
    local allPrompts = getWorkspacePrompts()
    for _, cropName in ipairs(PriorityCrops) do
        for _, prompt in ipairs(allPrompts) do
            local parentName = prompt.Parent and string.lower(prompt.Parent.Name) or ""
            local promptText = string.lower(prompt.ObjectText .. prompt.ActionText .. prompt.Name)
            
            if string.find(promptText, "harvest") or string.find(parentName, "harvest") then
                if string.find(promptText, cropName) or string.find(parentName, cropName) then
                    local targetPart = prompt.Parent
                    if targetPart and targetPart:IsA("BasePart") then
                        if (targetPart.Position - myPosition).Magnitude > 50 then
                            return prompt, targetPart
                        end
                    end
                end
            end
        end
    end
    return nil, nil
end

-- [Button 1]: Auto Steal
StealButton.MouseButton1Click:Connect(function()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    if stealStep == 1 then
        homeCFrame = rootPart.CFrame
        StealButton.Text = "Activate Auto Steal 🚀"
        StealButton.BackgroundColor3 = Color3.fromRGB(30, 144, 255)
        stealStep = 2
    elseif stealStep == 2 then
        autoStealing = not autoStealing
        if autoStealing then
            StealButton.Text = "Stealing Active... ON 🔥"
            StealButton.BackgroundColor3 = Color3.fromRGB(50, 205, 50)
            
            task.spawn(function()
                while autoStealing do
                    if not homeCFrame then break end
                    if checkNearbyPlayers(rootPart) then
                        rootPart.CFrame = homeCFrame
                        task.wait(2)
                        continue
                    end
                    
                    local prompt, targetPart = findBestPrompt(homeCFrame.Position)
                    if prompt and targetPart then
                        rootPart.CFrame = targetPart.CFrame + Vector3.new(0, 2, 0)
                        task.wait(tpDelay) 
                        
                        prompt.RequiresLineOfSight = false
                        prompt.MaxActivationDistance = 999
                        fireproximityprompt(prompt)
                        
                        task.wait(backDelay)
                        rootPart.CFrame = homeCFrame
                        task.wait(loopDelay) 
                    else
                        task.wait(1.5) 
                    end
                end
            end)
        else
            StealButton.Text = "Activate Auto Steal 🚀"
            StealButton.BackgroundColor3 = Color3.fromRGB(30, 144, 255)
        end
    end
end)

-- [Button 2]: Remote Harvest
HarvestButton.MouseButton1Click:Connect(function()
    harvesting = not harvesting
    if harvesting then
        HarvestButton.Text = "Remote Harvesting... ON 🌾"
        HarvestButton.BackgroundColor3 = Color3.fromRGB(50, 205, 50)
        
        task.spawn(function()
            while harvesting do
                local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                
                if rootPart then
                    local originalPosition = rootPart.CFrame
                    
                    for _, v in ipairs(workspace:GetDescendants()) do
                        if not harvesting then break end
                        if checkNearbyPlayers(rootPart) then
                            rootPart.CFrame = originalPosition
                            task.wait(2)
                            break
                        end
                        
                        local isHarvest = string.find(string.lower(v.Name), "harvest") 
                                          or (v:IsA("ProximityPrompt") and string.find(string.lower(v.ObjectText), "harvest"))
                                          or (v:IsA("ProximityPrompt") and string.find(string.lower(v.ActionText), "harvest"))
                        
                        if isHarvest then
                            local targetPart = v.Parent
                            if targetPart and targetPart:IsA("BasePart") then
                                rootPart.CFrame = targetPart.CFrame + Vector3.new(0, 2, 0)
                                task.wait(tpDelay)
                                
                                if v:IsA("ProximityPrompt") then
                                    v.RequiresLineOfSight = false
                                    v.MaxActivationDistance = 999999
                                    fireproximityprompt(v)
                                elseif v:IsA("ClickDetector") then
                                    fireclickdetector(v)
                                elseif v:IsA("TouchTransmitter") then
                                    firetouchinterest(rootPart, targetPart, 0)
                                    task.wait()
                                    firetouchinterest(rootPart, targetPart, 1)
                                end
                                task.wait(backDelay)
                            end
                        end
                    end
                    rootPart.CFrame = originalPosition
                end
                task.wait(loopDelay + 0.5) 
            end
        end)
    else
        HarvestButton.Text = "Remote Harvest: OFF 🌾"
        HarvestButton.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
    end
end)

